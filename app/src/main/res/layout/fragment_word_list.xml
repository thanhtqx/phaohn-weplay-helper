<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/screen_pad_h"
    android:paddingTop="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/search_height"
        android:background="@drawable/bg_search_field"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp">

        <ImageView
            android:layout_width="@dimen/search_icon"
            android:layout_height="@dimen/search_icon"
            android:contentDescription="@null"
            android:src="@drawable/ic_search" />

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="center_vertical"
            android:hint="@string/words_search_hint"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1"
            android:padding="0dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="@dimen/search_text" />

        <TextView
            android:id="@+id/searchStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_stats_chip"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textColor="@color/primary"
            android:textSize="10sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnLookup"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/lookup_btn"
            android:padding="5dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_search" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/lookupResultCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/card_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="10dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageButton
                    android:id="@+id/btnCloseLookup"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="top|end"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/close"
                    android:padding="4dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_close"
                    app:tint="@color/text_hint" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_search_field"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp"
                    android:paddingTop="18dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/lookupMyWord"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/word_placeholder"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:layout_marginHorizontal="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/card_stroke" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/surface"
                        android:paddingHorizontal="10dp"
                        android:text="@string/word_my_label"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/card_stroke" />
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_search_field"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp"
                    android:paddingTop="18dp"
                    android:paddingBottom="8dp">

                    <ScrollView
                        android:id="@+id/lookupResultsScroll"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxHeight="@dimen/lookup_words_max_height"
                        android:overScrollMode="never"
                        android:scrollbars="vertical">

                        <TextView
                            android:id="@+id/lookupResults"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:lineSpacingExtra="2dp"
                            android:text="@string/word_searching"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </ScrollView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:layout_marginHorizontal="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/card_stroke" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/surface"
                        android:paddingHorizontal="10dp"
                        android:text="@string/word_search_label"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/card_stroke" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnSync"
            android:layout_width="@dimen/sync_action_size"
            android:layout_height="@dimen/sync_action_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/sync_cloud"
            android:padding="@dimen/sync_action_padding"
            android:scaleType="centerInside"
            android:src="@drawable/ic_sync"
            app:tint="@color/primary" />

        <ImageButton
            android:id="@+id/btnImport"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/import_excel"
            android:padding="5dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_import" />

        <ImageButton
            android:id="@+id/btnExport"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/export_excel"
            android:padding="5dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_export" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddWord"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginStart="4dp"
            android:minWidth="0dp"
            android:paddingHorizontal="10dp"
            android:text="@string/add_word_short"
            android:textSize="11sp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_add_word"
            app:iconPadding="4dp"
            app:iconSize="16dp"
            app:rippleColor="@color/nav_ripple" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/card_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="true"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_table_header_rounded"
                android:gravity="center_vertical"
                android:minHeight="34dp"
                android:orientation="horizontal"
                android:paddingVertical="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/table_civilian"
                    android:textColor="@color/civilian"
                    android:textSize="@dimen/table_header_text"
                    android:textStyle="bold" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/table_divider" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/table_spy"
                    android:textColor="@color/spy"
                    android:textSize="@dimen/table_header_text"
                    android:textStyle="bold" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/table_divider" />

                <TextView
                    android:layout_width="@dimen/table_action_width"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/table_action"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/table_header_text"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerPairs"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:scrollbars="vertical" />

                <TextView
                    android:id="@+id/emptyText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/word_list_empty"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>