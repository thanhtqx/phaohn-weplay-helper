<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_table_row_grid"
    android:gravity="center_vertical"
    android:minHeight="38dp"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/table_row_pad">

    <TextView
        android:id="@+id/historyStt"
        android:layout_width="@dimen/table_stt_width"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/table_text" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/table_divider" />

    <TextView
        android:id="@+id/historyTime"
        android:layout_width="@dimen/table_time_width"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="1"
        android:paddingHorizontal="3dp"
        android:textColor="@color/text_secondary"
        android:textSize="10sp" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/table_divider" />

    <TextView
        android:id="@+id/historyMyWord"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:paddingHorizontal="4dp"
        android:textColor="@color/civilian"
        android:textSize="@dimen/table_text"
        android:textStyle="bold" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/table_divider" />

    <TextView
        android:id="@+id/historyOthers"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.1"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:paddingHorizontal="4dp"
        android:textColor="@color/spy"
        android:textSize="@dimen/table_text" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/table_divider" />

    <ImageButton
        android:id="@+id/btnDeleteHistory"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/delete"
        android:padding="7dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_delete" />
</LinearLayout>