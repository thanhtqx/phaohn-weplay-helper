<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/overlay_bubble_bg"
    android:minWidth="120dp"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingVertical="6dp">

    <LinearLayout
        android:id="@+id/overlayDragHandle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/my_word"
            android:textColor="#99BBDEFB"
            android:textSize="8sp" />

        <TextView
            android:id="@+id/overlayMyWord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/other_word"
            android:textColor="#99FFCC80"
            android:textSize="8sp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/overlayScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fadeScrollbars="false"
        android:maxHeight="140dp"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/overlayOtherWord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2dp"
            android:paddingTop="2dp"
            android:text=""
            android:textColor="#E6FFAB40"
            android:textSize="10sp" />
    </ScrollView>
</LinearLayout>