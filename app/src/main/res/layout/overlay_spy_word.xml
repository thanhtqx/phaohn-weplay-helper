<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/overlayWindowRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <View
        android:id="@+id/overlayScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_scrim"
        android:clickable="true"
        android:focusable="false"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/overlayRoot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/overlayChip"
            android:layout_width="@dimen/overlay_fab_size"
            android:layout_height="@dimen/overlay_fab_size"
            android:background="@drawable/bg_overlay_fab_selector"
            android:contentDescription="@string/overlay_chip_tap"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/overlayFabIcon"
                android:layout_width="@dimen/overlay_fab_icon"
                android:layout_height="@dimen/overlay_fab_icon"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_app_mark" />

            <TextView
                android:id="@+id/overlayFabBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="1dp"
                android:layout_marginEnd="1dp"
                android:background="@drawable/bg_overlay_badge"
                android:gravity="center"
                android:minWidth="14dp"
                android:minHeight="14dp"
                android:paddingHorizontal="3dp"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="7"
                tools:visibility="visible" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/overlayMenu"
            android:layout_width="@dimen/overlay_menu_width"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_overlay_menu"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingBottom="6dp"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/overlay_pad_h"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_app_mark" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_overlay_tab_bar"
                    android:orientation="horizontal"
                    android:padding="3dp">

                    <TextView
                        android:id="@+id/overlayTabWords"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_overlay_tab_pill_selector"
                        android:gravity="center"
                        android:paddingVertical="6dp"
                        android:text="@string/overlay_tab_words"
                        android:textColor="@color/overlay_text_primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/overlayTabAuto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_overlay_tab_pill_selector"
                        android:gravity="center"
                        android:paddingVertical="6dp"
                        android:text="@string/overlay_tab_auto"
                        android:textColor="@color/overlay_text_muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/overlayMenuClose"
                    android:layout_width="@dimen/overlay_sync_size"
                    android:layout_height="@dimen/overlay_sync_size"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_overlay_chip_selector"
                    android:contentDescription="@string/close"
                    android:padding="@dimen/overlay_sync_padding"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_close"
                    app:tint="@color/overlay_text_muted" />

                <ImageView
                    android:id="@+id/overlaySyncIcon"
                    android:layout_width="@dimen/overlay_sync_size"
                    android:layout_height="@dimen/overlay_sync_size"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_overlay_chip_selector"
                    android:contentDescription="@string/sync_cloud"
                    android:padding="@dimen/overlay_sync_padding"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_sync"
                    app:tint="@color/overlay_text_muted" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_overlay_divider" />

            <FrameLayout
                android:id="@+id/overlayPanelHost"
                android:layout_width="match_parent"
                android:layout_height="@dimen/overlay_menu_max_height">

                <ScrollView
                    android:id="@+id/overlayWordsPanel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/overlay_pad_h"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_overlay_field"
                                android:orientation="vertical"
                                android:paddingHorizontal="8dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="8dp">

                                <TextView
                                    android:id="@+id/overlayMyWord"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="@string/word_placeholder"
                                    android:textColor="@color/overlay_text_primary"
                                    android:textSize="@dimen/overlay_word_body"
                                    android:textStyle="bold"
                                    tools:text="Mỹ Tâm" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top"
                                android:layout_marginHorizontal="2dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1"
                                    android:background="@color/overlay_divider" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@color/overlay_legend_bg"
                                    android:paddingHorizontal="8dp"
                                    android:text="@string/word_my_label"
                                    android:textColor="@color/overlay_text_primary"
                                    android:textSize="@dimen/overlay_word_legend"
                                    android:textStyle="bold" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1"
                                    android:background="@color/overlay_divider" />
                            </LinearLayout>
                        </FrameLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_overlay_field"
                                android:orientation="vertical"
                                android:paddingHorizontal="8dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="8dp">

                                <ScrollView
                                    android:id="@+id/overlayOtherWordScroll"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:maxHeight="@dimen/overlay_list_height"
                                    android:overScrollMode="never"
                                    android:scrollbars="vertical">

                                    <TextView
                                        android:id="@+id/overlayOtherWord"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center"
                                        android:lineSpacingExtra="2dp"
                                        android:text="@string/word_searching"
                                        android:textColor="@color/overlay_text_hint"
                                        android:textSize="@dimen/overlay_word_list"
                                        tools:text="Từ 1\nTừ 2" />
                                </ScrollView>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top"
                                android:layout_marginHorizontal="2dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1"
                                    android:background="@color/overlay_divider" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@color/overlay_legend_bg"
                                    android:paddingHorizontal="8dp"
                                    android:text="@string/word_search_label"
                                    android:textColor="@color/overlay_text_primary"
                                    android:textSize="@dimen/overlay_word_legend"
                                    android:textStyle="bold" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1"
                                    android:background="@color/overlay_divider" />
                            </LinearLayout>
                        </FrameLayout>
                    </LinearLayout>
                </ScrollView>

                <ScrollView
                    android:id="@+id/overlayAutoPanel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:overScrollMode="never"
                    android:scrollbars="none"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/overlayAutoContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/overlay_pad_h"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_overlay_field"
                                android:orientation="vertical"
                                android:paddingHorizontal="8dp"
                                android:paddingTop="16dp"
                                android:paddingBottom="10dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:id="@+id/overlayAutoReady"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="5dp"
                                        android:layout_weight="1"
                                        android:background="@drawable/bg_overlay_toggle_ready_selector"
                                        android:gravity="center"
                                        android:minHeight="34dp"
                                        android:paddingVertical="8dp"
                                        android:text="@string/overlay_auto_ready"
                                        android:textColor="@color/overlay_text_primary"
                                        android:textSize="11sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/overlayAutoSit"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:background="@drawable/bg_overlay_toggle_sit_selector"
                                        android:gravity="center"
                                        android:minHeight="34dp"
                                        android:paddingVertical="8dp"
                                        android:text="@string/overlay_auto_sit"
                                        android:textColor="@color/overlay_text_primary"
                                        android:textSize="11sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top"
                                android:layout_marginHorizontal="2dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1"
                                    android:background="@color/overlay_divider" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@color/overlay_legend_bg"
                                    android:paddingHorizontal="8dp"
                                    android:text="@string/features_title"
                                    android:textColor="@color/overlay_text_primary"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1"
                                    android:background="@color/overlay_divider" />
                            </LinearLayout>
                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/overlayVotePanel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            tools:visibility="visible">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_overlay_field"
                                android:orientation="vertical"
                                android:paddingHorizontal="8dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="10dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="@string/vote_seat_section_label"
                                    android:textColor="@color/overlay_text_hint"
                                    android:textSize="10sp" />

                                <LinearLayout
                                    android:id="@+id/overlaySeatRow1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:orientation="horizontal" />

                                <LinearLayout
                                    android:id="@+id/overlaySeatRow2"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:orientation="horizontal" />

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    android:layout_marginVertical="8dp"
                                    android:background="@color/overlay_divider" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="@string/vote_tap_section_label"
                                    android:textColor="@color/overlay_text_hint"
                                    android:textSize="10sp" />

                                <LinearLayout
                                    android:id="@+id/overlaySecRow1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:orientation="horizontal" />

                                <LinearLayout
                                    android:id="@+id/overlaySecRow2"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:orientation="horizontal" />

                                <TextView
                                    android:id="@+id/overlayVoteLock"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:background="@drawable/bg_overlay_vote_row_selector"
                                    android:gravity="center"
                                    android:minHeight="36dp"
                                    android:paddingHorizontal="14dp"
                                    android:paddingVertical="8dp"
                                    android:text="@string/auto_vote_lock_action_lock"
                                    android:textColor="@color/overlay_text_primary"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top"
                                android:layout_marginHorizontal="2dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1"
                                    android:background="@color/overlay_divider" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@color/overlay_legend_bg"
                                    android:paddingHorizontal="8dp"
                                    android:text="@string/auto_vote_settings_title"
                                    android:textColor="@color/overlay_text_primary"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1"
                                    android:background="@color/overlay_divider" />
                            </LinearLayout>
                        </FrameLayout>
                    </LinearLayout>
                </ScrollView>
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>