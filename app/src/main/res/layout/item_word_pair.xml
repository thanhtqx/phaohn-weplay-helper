<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_table_row_grid"
    android:gravity="center_vertical"
    android:minHeight="38dp"
    android:orientation="horizontal"
    android:paddingVertical="7dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="4dp">

        <TextView
            android:id="@+id/civilianText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:textColor="@color/civilian"
            android:textSize="@dimen/table_text" />

        <TextView
            android:id="@+id/pendingBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_pending_badge"
            android:paddingHorizontal="6dp"
            android:paddingVertical="1dp"
            android:text="@string/word_pending_badge"
            android:textColor="#B54708"
            android:textSize="9sp"
            android:visibility="gone" />
    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/table_divider" />

    <TextView
        android:id="@+id/spyText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:paddingHorizontal="4dp"
        android:textColor="@color/spy"
        android:textSize="@dimen/table_text" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/table_divider" />

    <LinearLayout
        android:layout_width="@dimen/table_action_width"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnReport"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/report"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_report" />

        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/edit"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_edit" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/delete"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_delete" />
    </LinearLayout>
</LinearLayout>