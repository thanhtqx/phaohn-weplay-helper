<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="8dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp"
        android:text="@string/add_word_title"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/addModeToggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/modeSingle"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:text="@string/add_mode_single"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            app:cornerRadius="8dp"
            app:strokeColor="@color/card_stroke" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/modeMulti"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:text="@string/add_mode_multi"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            app:cornerRadius="8dp"
            app:strokeColor="@color/card_stroke" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <LinearLayout
        android:id="@+id/singleFields"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <EditText
            android:id="@+id/inputCivilian"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dialog_field"
            android:hint="@string/civilian_word"
            android:inputType="text"
            android:maxLines="2"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/inputSpy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_dialog_field"
            android:hint="@string/spy_word"
            android:inputType="text"
            android:maxLines="2"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/multiFields"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="6dp"
            android:text="@string/add_multi_label"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/inputMultiLines"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dialog_field"
            android:gravity="top|start"
            android:hint="@string/add_multi_hint"
            android:inputType="textMultiLine"
            android:lineSpacingExtra="3dp"
            android:minLines="5"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>