[Unit]
Description=PhaoHN Word Sync API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/phaohn
EnvironmentFile=-/opt/phaohn/.env
Environment=PATH=/opt/phaohn/venv/bin
ExecStart=/opt/phaohn/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target